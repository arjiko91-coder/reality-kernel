{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/arjiko91-coder/reality-kernel/physics_truth_suite/schema.json",
  "title": "Physics Truth Suite Experiment",
  "type": "object",
  "required": ["id", "category", "title", "ground_truth", "validation_target"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^RK-[A-Z]+-[0-9]{3}$"
    },
    "category": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "ground_truth": {
      "type": "string"
    },
    "validation_target": {
      "type": "string"
    },
    "source": {
      "type": "string"
    },
    "inputs": {
      "type": "object",
      "additionalProperties": true
    },
    "tolerance": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
